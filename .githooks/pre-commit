#!/usr/bin/env node
/**
 * Purpose: Run local staged secret scan before commit.
 */
import { spawnSync } from 'node:child_process';

const r = spawnSync('node', ['scripts/precommitSecretScan.js'], {
  stdio: 'inherit',
  shell: process.platform === 'win32',
});

process.exit(r.status ?? 1);
